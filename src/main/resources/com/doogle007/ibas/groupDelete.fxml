<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.effect.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<StackPane style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.doogle007.ibas.controller.GroupController">
   <children>
      <StackPane style="-fx-background-color: #FFFFFF;">
         <effect>
            <Shadow blurType="GAUSSIAN" color="#0000007e" height="40.0" radius="19.5" width="40.0" />
         </effect>
      </StackPane>
      <VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="200.0" prefWidth="300.0" style="-fx-background-color: #ffffff;">
         <children>
            <HBox fx:id="root" alignment="CENTER_RIGHT" prefHeight="40.0" style="-fx-background-color: #eeeeee;">
               <padding>
                  <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
               </padding>
               <children>
                  <StackPane fx:id="buttonClose" onMouseClicked="#onButtonCloseClick" onMouseEntered="#onButtonCloseEnter" onMouseExited="#onButtonCloseExit" prefHeight="30.0" prefWidth="30.0">
                     <children>
                        <Line endX="33.0" endY="33.0" startX="17.0" startY="17.0" stroke="#9f9f9f" strokeWidth="2.0" />
                        <Line endX="17.0" endY="33.0" startX="33.0" startY="17.0" stroke="#9f9f9f" strokeWidth="2.0" />
                     </children>
                  </StackPane>
               </children>
            </HBox>
            <VBox alignment="TOP_CENTER" spacing="10.0">
               <children>
                  <Label fx:id="labelNotice" text="是否删除该设备组？" />
                  <Button fx:id="buttonDelete" mnemonicParsing="false" onMouseClicked="#onButtonDeleteClick" text="确认" />
                  <Label fx:id="labelFail" />
                  <CheckBox fx:id="checkBoxDelete" mnemonicParsing="false" text="保留组内设备至未归类组" />
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</StackPane>
